generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Driver {
  id                   String               @id @default(cuid())
  clerkUserId          String?              @unique @map("clerk_user_id")
  fullName             String?              @map("full_name")
  email                String?              @unique
  phone                String?
  vehicleType          String?              @map("vehicle_type")
  area                 String?
  daysPreference       String?              @map("days_preference")
  stripeCustomerId     String?              @map("stripe_customer_id")
  stripeSubscriptionId String?              @map("stripe_subscription_id")
  subscriptionStatus   String?              @default("inactive") @map("subscription_status")
  ratingAvg            Decimal?             @map("rating_avg")
  ratingCount          Int?                 @default(0) @map("rating_count")
  profileLive          Boolean?             @default(false) @map("profile_live")
  lastSeenAt           DateTime?            @map("last_seen_at")
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @default(now()) @updatedAt @map("updated_at")
  postcode             String?              @db.VarChar(20)
  latitude             Decimal?             @db.Decimal(10, 8)
  longitude            Decimal?             @db.Decimal(11, 8)
  radius_miles         Int?                 @default(10)
  available_days       String[]
  b2b_opt_in           Boolean?             @default(false)
  b2b_leads            B2bLead[]
  availability         DriverAvailability[]
  earnings             Earning[]
  invoices             JobInvoice[]
  jobs                 Job[]
  ratings              Rating[]

  @@index([lastSeenAt])
  @@index([profileLive])
  @@index([postcode], map: "idx_drivers_postcode")
  @@map("drivers")
}

model DriverAvailability {
  id            String   @id @default(cuid())
  driverId      String   @map("driver_id")
  availableDate DateTime @map("available_date") @db.Date
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  driver        Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@unique([driverId, availableDate])
  @@map("driver_availability")
}

model Job {
  id                   String                  @id @default(cuid())
  reference            String                  @unique
  trackingToken        String                  @unique @map("tracking_token")
  customerName         String?                 @map("customer_name")
  customerEmail        String?                 @map("customer_email")
  customerPhone        String?                 @map("customer_phone")
  serviceType          String?                 @map("service_type")
  postcodeFrom         String?                 @map("postcode_from")
  postcodeTo           String?                 @map("postcode_to")
  distanceMiles        Int?                    @map("distance_miles")
  largeItems           Json?                   @map("large_items")
  timeframe            String?
  helpLoading          String?                 @map("help_loading")
  duration             String?
  driverId             String?                 @map("driver_id")
  status               String?                 @default("new")
  jobDate              DateTime?               @map("job_date") @db.Date
  price                Decimal?
  notes                String?
  leadId               String?                 @map("lead_id")
  offeredAt            DateTime?               @map("offered_at")
  confirmedAt          DateTime?               @map("confirmed_at")
  inProgressAt         DateTime?               @map("in_progress_at")
  completedAt          DateTime?               @map("completed_at")
  pickupLat            Decimal?                @map("pickup_lat")
  pickupLng            Decimal?                @map("pickup_lng")
  driverLat            Decimal?                @map("driver_lat")
  driverLng            Decimal?                @map("driver_lng")
  driverEtaMinutes     Int?                    @map("driver_eta_minutes")
  locationSharingSince DateTime?               @map("location_sharing_since")
  createdAt            DateTime                @default(now()) @map("created_at")
  updatedAt            DateTime                @updatedAt @map("updated_at")
  arrivedDeliveryAt    DateTime?               @map("arrived_delivery_at")
  arrivedPickupAt      DateTime?               @map("arrived_pickup_at")
  collectedAt          DateTime?               @map("collected_at")
  collectionPhotoUrl   String?                 @map("collection_photo_url")
  deliveryPhotoUrl     String?                 @map("delivery_photo_url")
  recipientName        String?                 @map("recipient_name")
  requiresSignature    Boolean                 @default(false) @map("requires_signature")
  address_from         String?
  address_to           String?
  locationHistory      DriverLocationHistory[]
  earnings             Earning[]
  events               JobEvent[]
  invoices             JobInvoice[]
  photos               JobPhoto[]
  driver               Driver?                 @relation(fields: [driverId], references: [id])
  ratings              Rating?

  @@index([driverId, status])
  @@index([customerEmail])
  @@index([status])
  @@index([createdAt])
  @@index([updatedAt])
  @@map("jobs")
}

model Rating {
  id        String   @id @default(cuid())
  jobId     String?  @unique @map("job_id")
  driverId  String?  @map("driver_id")
  score     Int?
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")
  driver    Driver?  @relation(fields: [driverId], references: [id])
  job       Job?     @relation(fields: [jobId], references: [id])

  @@index([driverId])
  @@map("ratings")
}

model DriverLocationHistory {
  id            String   @id @default(cuid())
  jobId         String?  @map("job_id")
  driverClerkId String?  @map("driver_clerk_id")
  lat           Decimal?
  lng           Decimal?
  accuracy      Decimal?
  etaMinutes    Int?     @map("eta_minutes")
  recordedAt    DateTime @default(now()) @map("recorded_at")
  job           Job?     @relation(fields: [jobId], references: [id])

  @@index([jobId])
  @@index([recordedAt])
  @@index([jobId], map: "idx_dlh_job_id")
  @@index([recordedAt], map: "idx_dlh_recorded_at")
  @@map("driver_location_history")
}

model Earning {
  id        String    @id @default(cuid())
  driverId  String?   @map("driver_id")
  jobId     String?   @map("job_id")
  amount    Decimal?
  status    String?   @default("pending")
  paidAt    DateTime? @map("paid_at")
  notes     String?
  createdAt DateTime  @default(now()) @map("created_at")
  driver    Driver?   @relation(fields: [driverId], references: [id])
  job       Job?      @relation(fields: [jobId], references: [id])

  @@map("earnings")
}

model JobEvent {
  id        String       @id @default(cuid())
  jobId     String       @map("job_id")
  eventType JobEventType @map("event_type")
  latitude  Decimal?
  longitude Decimal?
  timestamp DateTime     @default(now())
  createdAt DateTime     @default(now()) @map("created_at")
  job       Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  photos    JobPhoto[]

  @@index([jobId])
  @@index([timestamp])
  @@map("job_events")
}

model JobPhoto {
  id         String       @id @default(cuid())
  jobId      String       @map("job_id")
  jobEventId String?      @map("job_event_id")
  photoType  JobPhotoType @map("photo_type")
  photoUrl   String       @map("photo_url")
  latitude   Decimal?
  longitude  Decimal?
  uploadedAt DateTime     @default(now()) @map("uploaded_at")
  createdAt  DateTime     @default(now()) @map("created_at")
  jobEvent   JobEvent?    @relation(fields: [jobEventId], references: [id])
  job        Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([jobEventId])
  @@map("job_photos")
}

model JobInvoice {
  id            String           @id @default(cuid())
  jobId         String           @map("job_id")
  driverId      String           @map("driver_id")
  invoiceNumber String           @unique @map("invoice_number")
  amount        Decimal
  status        JobInvoiceStatus @default(pending)
  issuedAt      DateTime         @default(now()) @map("issued_at")
  paidAt        DateTime?        @map("paid_at")
  createdAt     DateTime         @default(now()) @map("created_at")
  driver        Driver           @relation(fields: [driverId], references: [id], onDelete: Cascade)
  job           Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([driverId])
  @@index([status])
  @@map("job_invoices")
}

model B2bLead {
  id                          String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  businessName                String                       @map("business_name")
  businessCategory            String?                      @map("business_category")
  contactName                 String?                      @map("contact_name")
  email                       String?
  phone                       String?
  website                     String?
  city                        String?
  postcode                    String?
  googlePlaceId               String?                      @map("google_place_id")
  painPoint                   String?                      @map("pain_point")
  painPointReview             String?                      @map("pain_point_review")
  reviewRating                Decimal?                     @map("review_rating") @db.Decimal(2, 1)
  source                      String?                      @default("discovery")
  status                      String?                      @default("new")
  notes                       String?
  niche                       String?
  landingPageUrl              String?                      @map("landing_page_url")
  businessEvidence            Json?                        @map("business_evidence")
  humanObservations           Json?                        @map("human_observations")
  businessTimeline            Json?                        @map("business_timeline")
  createdAt                   DateTime                     @default(now()) @map("created_at")
  updatedAt                   DateTime                     @updatedAt @map("updated_at")
  leadState                   String?                      @default("new") @map("lead_state")
  transitionedAt              DateTime?                    @map("transitioned_at") @db.Timestamptz(6)
  driver_id                   String?
  latitude                    Decimal?                     @db.Decimal(10, 8)
  longitude                   Decimal?                     @db.Decimal(11, 8)
  email_sent_at               DateTime?                    @db.Timestamptz(6)
  qualified_business_id       String?                      @unique(map: "uq_b2b_leads_qualified_business") @db.Uuid
  discovered_business_id      String?                      @db.Uuid
  promoted_from_qualified_at  DateTime?                    @db.Timestamptz(6)
  outreach_eligible           Boolean?                     @default(false)
  engagement_score            Int?                         @default(0)
  last_engagement_at          DateTime?                    @db.Timestamptz(6)
  lead_tier                   String?
  engaged_today               Boolean?                     @default(false)
  last_engagement_type        String?
  pipeline_stage              String?                      @default("NEW") @map("pipeline_stage")
  channel                     String?                      @default("whatsapp") @map("channel")
  company_size                String?                      @map("company_size")
  b2b_email_events            b2b_email_events[]
  b2b_email_link_clicks       b2b_email_link_clicks[]
  b2b_heat_score_history      b2b_heat_score_history[]
  discovered_businesses       discovered_businesses?       @relation(fields: [discovered_business_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  drivers                     Driver?                      @relation(fields: [driver_id], references: [id], onUpdate: NoAction)
  qualified_businesses        qualified_businesses?        @relation(fields: [qualified_business_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  b2b_learning_outcomes       b2b_learning_outcomes[]
  outreach                    B2bOutreach[]
  b2b_prospect_brief_cache    b2b_prospect_brief_cache?
  b2b_prospect_qualifications b2b_prospect_qualifications?
  standingOrders              B2bStandingOrder[]
  lead_promotions             lead_promotions[]
  lead_state_transitions      lead_state_transitions[]
  conversationEvents          B2bConversationEvent[]
  revenueEvents               B2bRevenueEvent[]
  tasks                       B2bTask[]
  activityLogs                B2bActivityLog[]

  @@index([status])
  @@index([createdAt])
  @@index([createdAt(sort: Desc)], map: "idx_b2b_leads_created")
  @@index([driver_id], map: "idx_b2b_leads_driver")
  @@index([engaged_today], map: "idx_b2b_leads_engaged_today")
  @@index([engagement_score(sort: Desc), last_engagement_at(sort: Desc)], map: "idx_b2b_leads_engagement")
  @@index([leadState], map: "idx_b2b_leads_lead_state")
  @@index([pipeline_stage], map: "idx_b2b_leads_pipeline_stage")
  @@index([qualified_business_id], map: "idx_b2b_leads_qualified_business")
  @@index([status], map: "idx_b2b_leads_status")
  @@index([lead_tier], map: "idx_b2b_leads_tier")
  @@map("b2b_leads")
}

model B2bOutreach {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leadId           String             @map("lead_id") @db.Uuid
  subject          String?
  body             String?
  sentAt           DateTime?          @map("sent_at")
  followUp1At      DateTime?          @map("follow_up_1_at")
  followUp2At      DateTime?          @map("follow_up_2_at")
  replied          Boolean?           @default(false)
  repliedAt        DateTime?          @map("replied_at")
  emailType        String?            @default("initial") @map("email_type")
  resendMessageId  String?            @map("resend_message_id")
  createdAt        DateTime           @default(now()) @map("created_at")
  copy_variant     String?
  pressure_type    String?
  sent_by          String?            @default("autonomous")
  b2b_email_events b2b_email_events[]
  lead             B2bLead            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  b2b_responses    b2b_responses[]

  @@index([leadId])
  @@index([copy_variant])
  @@index([pressure_type])
  @@index([sent_by])
  @@index([leadId], map: "idx_b2b_outreach_lead")
  @@map("b2b_outreach")
}

model B2bStandingOrder {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leadId           String    @map("lead_id") @db.Uuid
  businessName     String    @map("business_name")
  contactName      String?   @map("contact_name")
  contactPhone     String?   @map("contact_phone")
  contactEmail     String?   @map("contact_email")
  pickupAddress    String?   @map("pickup_address")
  pickupPostcode   String?   @map("pickup_postcode")
  deliveryAddress  String?   @map("delivery_address")
  deliveryPostcode String?   @map("delivery_postcode")
  serviceType      String?   @map("service_type")
  frequency        String?   @default("weekly")
  dayOfWeek        Int?      @map("day_of_week")
  preferredTime    String?   @map("preferred_time")
  price            Decimal?  @db.Decimal(10, 2)
  notes            String?
  active           Boolean?  @default(true)
  lastGeneratedAt  DateTime? @map("last_generated_at")
  nextScheduledAt  DateTime? @map("next_scheduled_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at")
  lead             B2bLead   @relation(fields: [leadId], references: [id])

  @@map("b2b_standing_orders")
}

model B2bConversationEvent {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leadId    String   @map("lead_id") @db.Uuid
  lead      B2bLead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type      String
  direction String
  subject   String?
  body      String?
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([leadId])
  @@index([type])
  @@index([createdAt])
  @@map("b2b_conversation_events")
}

model B2bBehaviorMetrics {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  variantId    String? @map("variant_id")
  campaignId   String? @map("campaign_id")
  pressureType String? @map("pressure_type")

  sentCount     Int @default(0) @map("sent_count")
  openCount     Int @default(0) @map("open_count")
  clickCount    Int @default(0) @map("click_count")
  replyCount    Int @default(0) @map("reply_count")
  replyYesCount Int @default(0) @map("reply_yes_count")
  replyNoCount  Int @default(0) @map("reply_no_count")

  openRate  Decimal @default(0) @map("open_rate") @db.Decimal(5, 2)
  clickRate Decimal @default(0) @map("click_rate") @db.Decimal(5, 2)
  replyRate Decimal @default(0) @map("reply_rate") @db.Decimal(5, 2)
  yesRate   Decimal @default(0) @map("yes_rate") @db.Decimal(5, 2)

  dateRangeStart DateTime? @map("date_range_start")
  dateRangeEnd   DateTime? @map("date_range_end")

  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([variantId, campaignId, pressureType], map: "uq_b2b_behavior_metrics")
  @@index([yesRate(sort: Desc)], map: "idx_b2b_behavior_yes_rate")
  @@index([variantId], map: "idx_b2b_behavior_variant")
  @@index([campaignId], map: "idx_b2b_behavior_campaign")
  @@index([pressureType], map: "idx_b2b_behavior_pressure")
  @@map("b2b_behavior_metrics")
}

model B2bBehaviorSnapshot {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  date       DateTime @map("date")
  campaignId String?  @map("campaign_id")

  topVariantId     String? @map("top_variant_id")
  worstVariantId   String? @map("worst_variant_id")
  bestPressureType String? @map("best_pressure_type")

  totalSent Int @default(0) @map("total_sent")
  totalYes  Int @default(0) @map("total_yes")

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([date, campaignId], map: "uq_b2b_behavior_snapshot")
  @@index([date(sort: Desc)], map: "idx_b2b_behavior_snapshot_date")
  @@index([campaignId], map: "idx_b2b_behavior_snapshot_campaign")
  @@map("b2b_behavior_snapshots")
}

model B2bMemoryPattern {
  id   String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type String
  // VARIANT_WINNER | PRESSURE_TYPE_WINNER | SEQUENCE_PATTERN

  key String
  // e.g. "variant_v3", "pressure_urgency", "seq_open_click_reply"

  value Json
  // stores: variant_id, yes_rate OR type, conversion_rate OR sequence_pattern

  confidenceScore Decimal @default(0) @map("confidence_score") @db.Decimal(5, 2)
  evidenceCount   Int     @default(0) @map("evidence_count")

  campaignId String? @map("campaign_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  memoryLogs B2bLearningMemoryLog[]

  @@unique([type, key, campaignId], map: "uq_b2b_memory_pattern")
  @@index([type], map: "idx_b2b_memory_type")
  @@index([confidenceScore(sort: Desc)], map: "idx_b2b_memory_confidence")
  @@map("b2b_memory_patterns")
}

model B2bLearningMemoryLog {
  id        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patternId String           @map("pattern_id") @db.Uuid
  pattern   B2bMemoryPattern @relation(fields: [patternId], references: [id], onDelete: Cascade)

  eventTrigger String @map("event_trigger")
  // DAILY_RECALC | NEW_CAMPAIGN_END | MANUAL_UPDATE

  beforeValue Json? @map("before_value")
  afterValue  Json? @map("after_value")

  deltaScore Decimal @default(0) @map("delta_score") @db.Decimal(5, 2)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([patternId], map: "idx_b2b_memory_log_pattern")
  @@index([eventTrigger], map: "idx_b2b_memory_log_trigger")
  @@map("b2b_learning_memory_logs")
}

model B2bRevenueEvent {
  id     String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leadId String  @map("lead_id") @db.Uuid
  lead   B2bLead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  type String
  // CONVERSION | PAYMENT | DEAL_WON | DEAL_LOST

  value    Decimal @default(0) @db.Decimal(10, 2)
  currency String  @default("GBP")

  campaignId            String? @map("campaign_id")
  linkedBehaviorId      String? @map("linked_behavior_id") @db.Uuid
  linkedMemoryPatternId String? @map("linked_memory_pattern_id") @db.Uuid

  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([leadId], map: "idx_b2b_revenue_lead")
  @@index([type], map: "idx_b2b_revenue_type")
  @@index([createdAt(sort: Desc)], map: "idx_b2b_revenue_date")
  @@index([value(sort: Desc)], map: "idx_b2b_revenue_value")
  @@map("b2b_revenue_events")
}

model B2bRevenueAttribution {
  id               String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patternId        String  @map("pattern_id") @db.Uuid
  behaviorMetricId String? @map("behavior_metric_id") @db.Uuid

  totalRevenue    Decimal @default(0) @map("total_revenue") @db.Decimal(12, 2)
  conversionCount Int     @default(0) @map("conversion_count")

  revenuePerVariant  Decimal @default(0) @map("revenue_per_variant") @db.Decimal(10, 2)
  revenuePerPressure Decimal @default(0) @map("revenue_per_pressure") @db.Decimal(10, 2)

  roiScore        Decimal @default(0) @map("roi_score") @db.Decimal(5, 2)
  confidenceScore Decimal @default(0) @map("confidence_score") @db.Decimal(5, 2)

  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([patternId, behaviorMetricId], map: "uq_b2b_revenue_attribution")
  @@index([patternId], map: "idx_b2b_revenue_pattern")
  @@index([roiScore(sort: Desc)], map: "idx_b2b_revenue_roi")
  @@index([totalRevenue(sort: Desc)], map: "idx_b2b_revenue_total")
  @@map("b2b_revenue_attributions")
}

model B2bCampaignRevenueSummary {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId String @unique @map("campaign_id")

  totalRevenue   Decimal @default(0) @map("total_revenue") @db.Decimal(12, 2)
  totalProspects Int     @default(0) @map("total_prospects")

  bestRevenueVariant     String? @map("best_revenue_variant")
  bestRevenuePresureType String? @map("best_revenue_pressure_type")

  revenueConversionRate Decimal @default(0) @map("revenue_conversion_rate") @db.Decimal(5, 2)

  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([totalRevenue(sort: Desc)], map: "idx_b2b_campaign_revenue")
  @@map("b2b_campaign_revenue_summaries")
}

model B2bSafetyGuardrail {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ruleType String @map("rule_type")
  // REVENUE_DROP_PROTECTION | PATTERN_OVERFITTING_PROTECTION | RANDOM_SPIKE_FILTER | CAMPAIGN_STABILITY_LIMIT

  threshold Decimal @db.Decimal(10, 4)
  action    String
  // BLOCK_AUTOMATION | REVERT_TO_MEMORY | FALLBACK_VARIANT | REDUCE_CONFIDENCE

  severity String @default("MEDIUM")
  // LOW | MEDIUM | HIGH

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([ruleType], map: "idx_b2b_guardrail_type")
  @@index([isActive], map: "idx_b2b_guardrail_active")
  @@map("b2b_safety_guardrails")
}

model B2bSystemOverrideLog {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  trigger String
  // AUTOPILOT | HUMAN | GUARDRAIL

  previousDecision Json? @map("previous_decision")
  newDecision      Json? @map("new_decision")

  reason String

  impactScore Decimal @default(0) @map("impact_score") @db.Decimal(5, 2)

  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([trigger], map: "idx_b2b_override_trigger")
  @@index([createdAt(sort: Desc)], map: "idx_b2b_override_date")
  @@index([impactScore(sort: Desc)], map: "idx_b2b_override_impact")
  @@map("b2b_system_override_logs")
}

model B2bSystemHealth {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  learningStability Decimal @default(0) @map("learning_stability") @db.Decimal(5, 2)
  revenueVolatility String  @default("LOW")
  // LOW | MEDIUM | HIGH

  patternConfidenceDrift    Decimal @default(0) @map("pattern_confidence_drift") @db.Decimal(5, 2)
  guardrailTriggersSevenDay Int     @default(0) @map("guardrail_triggers_7d")

  systemMode String @default("MANUAL")
  // MANUAL | ASSISTED | AUTOPILOT

  lastAnomalyDetected DateTime? @map("last_anomaly_detected")

  createdAt DateTime @default(now()) @map("created_at")
