  enriched_businesses     enriched_businesses?    @relation(fields: [enriched_business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([promoted_to_lead_at], map: "idx_qualified_businesses_promoted")
  @@index([opportunity_score(sort: Desc)], map: "idx_qualified_businesses_score")
}

