// This is a REALITY CAPTURE SYSTEM, not an intelligence system.
//
// It stores:
// - what exists (Business)
// - what was said (Review)
// - what was thought (Hypothesis)
// - what was asked (Conversation)
// - what happened (Outcome)
// - what belief changed over time (Assumption)
//
// It does NOT store:
// - what is good
// - what is better
// - what is likely
// - what is high value

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PipelineState {
  DISCOVERED
  EVIDENCE_COLLECTED
  INVESTIGATED
  INBOX_READY
}

// Purpose: What exists
model Business {
  id               String          @id @default(cuid())
  name             String
  placeId          String?         @unique
  address          String?
  phone            String?
  website          String?
  niche            String?
  location         String?
  sourceType       String?
  sourcePayload    Json?
  pipelineState    PipelineState   @default(DISCOVERED)
  discoveredAt     DateTime?
  createdAt        DateTime        @default(now())

  reviews          Review[]
  hypotheses       Hypothesis[]
  conversations    Conversation[]
  evidencePatterns EvidencePattern[]
}

// Purpose: What was said
model Review {
  id String @id @default(cuid())
  businessId String
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  text String
  rating Int?
  author String?
  createdAt DateTime @default(now())
}

// Purpose: Extracted evidence patterns from reviews
model EvidencePattern {
  id              String      @id @default(cuid())
  businessId      String
  business        Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)

  patternType     String      // Description from patterns.ts e.g. "Wedding-related work mentioned"
  occurrences     Int
  examples        Json        // String[] of actual review text excerpts
  createdAt       DateTime    @default(now())

  hypotheses      Hypothesis[]
}

// Purpose: What was thought (temporary interpretation)
// Status is informational only, never used for filtering, ranking, or logic
model Hypothesis {
  id                  String          @id @default(cuid())
  businessId          String
  business            Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  evidencePatternId   String?
  evidencePattern     EvidencePattern? @relation(fields: [evidencePatternId], references: [id])

  statement           String
  status              HypothesisStatus? // Informational only, never used for logic
  evidenceCount       Int             @default(0)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
}

enum HypothesisStatus {
  emerging
  supported
  weak
  rejected
}

// Purpose: What was asked
model Conversation {
  id          String      @id @default(cuid())
  businessId  String
  business    Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)

  question    String
  status      String      @default("pending")  // "pending" | "asked" | "answered"
  createdAt   DateTime    @default(now())

  outcome     Outcome?
}

// Purpose: What happened
model Outcome {
  id String @id @default(cuid())
  conversationId String @unique
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  signalType OutcomeSignal
  signalClassification SignalClassification
  unexpectedLearning String? // What surprised you? Stored exactly as written.
  createdAt DateTime @default(now())
}

enum OutcomeSignal {
  no_answer
  spoke_briefly
  real_conversation
  not_interested
  wrong_fit
}

enum SignalClassification {
  supports
  contradicts
  unclear
  new_signal
}

// Purpose: What belief statement exists
// Status is informational only, never used for logic.
// Links to observations happen externally via queries, never encoded in schema.
model Assumption {
  id String @id @default(cuid())

  statement String @unique
  status AssumptionStatus? // Informational only, never used for logic
}

enum AssumptionStatus {
  emerging
  supported
  weak
  rejected
}

// Purpose: Raw observation events (decoupled from interpretation)
// No links to assumptions. Interpretation happens externally via queries.
// This ensures: database is memory dump of reality, not a brain.
model ObservationEvent {
  id String @id @default(cuid())

  sourceType ObservationSource
  sourceId String // ID of the source (outcome, review, or conversation)
  text String // Raw observed signal
  createdAt DateTime @default(now())
}

enum ObservationSource {
  review
  conversation
  outcome
}
