// DUAL SCHEMA: Dispatch Platform + Discovery System
//
// DISPATCH PLATFORM (Original System)
// - drivers: Fleet management and authentication
// - jobs: Service requests and dispatch
// - earnings: Driver compensation tracking
//
// DISCOVERY SYSTEM (B2B Investigation)
// - Business: Prospect companies
// - Review: Evidence from review platforms
// - Hypothesis: Interpretations of evidence
// - Conversation: Outreach tracking
// - Outcome: Conversation results
// - Assumption: Beliefs being tested

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PipelineState {
  DISCOVERED
  EVIDENCE_COLLECTED
  INVESTIGATED
  INBOX_READY
}

// ============================================================================
// JOB EVENTS & OPERATIONS ENUMS
// ============================================================================

enum JobEventType {
  assigned
  accepted
  arrived_pickup
  collected
  on_way
  arrived_delivery
  delivered
}

enum JobPhotoType {
  collection
  delivery
}

enum JobInvoiceStatus {
  pending
  paid
  cancelled
}

// ============================================================================
// DISPATCH PLATFORM MODELS
// ============================================================================

model Driver {
  id                    String    @id @default(cuid())
  clerkUserId           String?   @unique @map("clerk_user_id")
  fullName              String?   @map("full_name")
  email                 String?   @unique
  phone                 String?
  vehicleType           String?   @map("vehicle_type")
  area                  String?
  daysPreference        String?   @map("days_preference")
  stripeCustomerId      String?   @map("stripe_customer_id")
  stripeSubscriptionId  String?   @map("stripe_subscription_id")
  subscriptionStatus    String?   @default("inactive") @map("subscription_status")
  ratingAvg             Decimal?  @map("rating_avg")
  ratingCount           Int?      @default(0) @map("rating_count")
  profileLive           Boolean?  @default(false) @map("profile_live")
  lastSeenAt            DateTime? @map("last_seen_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  availability          DriverAvailability[]
  jobs                  Job[]
  ratings               Rating[]
  earnings              Earning[]
  invoices              JobInvoice[]

  @@index([lastSeenAt])
  @@index([profileLive])
  @@map("drivers")
}

model DriverAvailability {
  id                String    @id @default(cuid())
  driverId          String    @map("driver_id")
  driver            Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)
  availableDate     DateTime  @map("available_date") @db.Date
  notes             String?
  createdAt         DateTime  @default(now()) @map("created_at")

  @@unique([driverId, availableDate])
  @@map("driver_availability")
}

model Job {
  id                String    @id @default(cuid())
  reference         String    @unique
  trackingToken     String    @unique @map("tracking_token")
  customerName      String?   @map("customer_name")
  customerEmail     String?   @map("customer_email")
  customerPhone     String?   @map("customer_phone")
  serviceType       String?   @map("service_type")
  postcodeFrom      String?   @map("postcode_from")
  postcodeTo        String?   @map("postcode_to")
  distanceMiles     Int?      @map("distance_miles")
  largeItems        Json?     @map("large_items")
  timeframe         String?
  helpLoading       String?   @map("help_loading")
  duration          String?
  driverId          String?   @map("driver_id")
  driver            Driver?   @relation(fields: [driverId], references: [id])
  status            String?   @default("new")
  jobDate           DateTime? @map("job_date") @db.Date
  price             Decimal?
  notes             String?
  leadId            String?   @map("lead_id")
  offeredAt         DateTime? @map("offered_at")
  confirmedAt       DateTime? @map("confirmed_at")
  inProgressAt      DateTime? @map("in_progress_at")
  completedAt       DateTime? @map("completed_at")
  pickupLat         Decimal?  @map("pickup_lat")
  pickupLng         Decimal?  @map("pickup_lng")
  driverLat         Decimal?  @map("driver_lat")
  driverLng         Decimal?  @map("driver_lng")
  driverEtaMinutes  Int?      @map("driver_eta_minutes")
  locationSharingSince DateTime? @map("location_sharing_since")

  // Job operations tracking
  arrivedPickupAt   DateTime? @map("arrived_pickup_at")
  collectedAt       DateTime? @map("collected_at")
  arrivedDeliveryAt DateTime? @map("arrived_delivery_at")
  collectionPhotoUrl String?  @map("collection_photo_url")
  deliveryPhotoUrl  String?   @map("delivery_photo_url")
  recipientName     String?   @map("recipient_name")
  requiresSignature Boolean   @default(false) @map("requires_signature")

  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  ratings           Rating[]
  earnings          Earning[]
  locationHistory   DriverLocationHistory[]
  events            JobEvent[]
  photos            JobPhoto[]
  invoices          JobInvoice[]

  @@index([driverId, status])
  @@index([customerEmail])
  @@index([status])
  @@index([createdAt])
  @@index([updatedAt])
  @@map("jobs")
}

model Rating {
  id                String    @id @default(cuid())
  jobId             String?   @unique @map("job_id")
  job               Job?      @relation(fields: [jobId], references: [id])
  driverId          String?   @map("driver_id")
  driver            Driver?   @relation(fields: [driverId], references: [id])
  score             Int?
  comment           String?
  createdAt         DateTime  @default(now()) @map("created_at")

  @@index([driverId])
  @@map("ratings")
}

model DriverLocationHistory {
  id                String    @id @default(cuid())
  jobId             String?   @map("job_id")
  job               Job?      @relation(fields: [jobId], references: [id])
  driverClerkId     String?   @map("driver_clerk_id")
  lat               Decimal?
  lng               Decimal?
  accuracy          Decimal?
  etaMinutes        Int?      @map("eta_minutes")
  recordedAt        DateTime  @default(now()) @map("recorded_at")

  @@index([jobId])
  @@index([recordedAt])
  @@map("driver_location_history")
}

model Earning {
  id                String    @id @default(cuid())
  driverId          String?   @map("driver_id")
  driver            Driver?   @relation(fields: [driverId], references: [id])
  jobId             String?   @map("job_id")
  job               Job?      @relation(fields: [jobId], references: [id])
  amount            Decimal?
  status            String?   @default("pending")
  paidAt            DateTime? @map("paid_at")
  notes             String?
  createdAt         DateTime  @default(now()) @map("created_at")

  @@map("earnings")
}

// ============================================================================
// JOB OPERATIONS MODELS
// ============================================================================

model JobEvent {
  id                String        @id @default(cuid())
  jobId             String        @map("job_id")
  job               Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  eventType         JobEventType  @map("event_type")
  latitude          Decimal?
  longitude         Decimal?
  timestamp         DateTime      @default(now())
  createdAt         DateTime      @default(now()) @map("created_at")

  photos            JobPhoto[]

  @@index([jobId])
  @@index([timestamp])
  @@map("job_events")
}

model JobPhoto {
  id                String        @id @default(cuid())
  jobId             String        @map("job_id")
  job               Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobEventId        String?       @map("job_event_id")
  jobEvent          JobEvent?     @relation(fields: [jobEventId], references: [id], onDelete: SetNull)
  photoType         JobPhotoType  @map("photo_type")
  photoUrl          String        @map("photo_url")
  latitude          Decimal?
  longitude         Decimal?
  uploadedAt        DateTime      @default(now()) @map("uploaded_at")
  createdAt         DateTime      @default(now()) @map("created_at")

  @@index([jobId])
  @@index([jobEventId])
  @@map("job_photos")
}

model JobInvoice {
  id                String            @id @default(cuid())
  jobId             String            @map("job_id")
  job               Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  driverId          String            @map("driver_id")
  driver            Driver            @relation(fields: [driverId], references: [id], onDelete: Cascade)
  invoiceNumber     String            @unique @map("invoice_number")
  amount            Decimal
  status            JobInvoiceStatus  @default(pending)
  issuedAt          DateTime          @default(now()) @map("issued_at")
  paidAt            DateTime?         @map("paid_at")
  createdAt         DateTime          @default(now()) @map("created_at")

  @@index([jobId])
  @@index([driverId])
  @@index([status])
  @@map("job_invoices")
}

// ============================================================================
// DISCOVERY SYSTEM MODELS
// ============================================================================

// Purpose: What exists
model Business {
  id               String          @id @default(cuid())
  name             String
  placeId          String?         @unique
  address          String?
  phone            String?
  website          String?
  niche            String?
  location         String?
  sourceType       String?
  sourcePayload    Json?
  pipelineState    PipelineState   @default(DISCOVERED)
  discoveredAt     DateTime?
  createdAt        DateTime        @default(now())

  reviews          Review[]
  hypotheses       Hypothesis[]
  conversations    Conversation[]
  evidencePatterns EvidencePattern[]
}

// Purpose: What was said
model Review {
  id String @id @default(cuid())
  businessId String
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  text String
  rating Int?
  author String?
  createdAt DateTime @default(now())
}

// Purpose: Extracted evidence patterns from reviews
model EvidencePattern {
  id              String      @id @default(cuid())
  businessId      String
  business        Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)

  patternType     String      // Description from patterns.ts e.g. "Wedding-related work mentioned"
  occurrences     Int
  examples        Json        // String[] of actual review text excerpts
  createdAt       DateTime    @default(now())

  hypotheses      Hypothesis[]
}

// Purpose: What was thought (temporary interpretation)
// Status is informational only, never used for filtering, ranking, or logic
model Hypothesis {
  id                  String          @id @default(cuid())
  businessId          String
  business            Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  evidencePatternId   String?
  evidencePattern     EvidencePattern? @relation(fields: [evidencePatternId], references: [id])

  statement           String
  status              HypothesisStatus? // Informational only, never used for logic
  evidenceCount       Int             @default(0)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
}

enum HypothesisStatus {
  emerging
  supported
  weak
  rejected
}

// Purpose: What was asked
model Conversation {
  id          String      @id @default(cuid())
  businessId  String
  business    Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)

  question    String
  status      String      @default("pending")  // "pending" | "asked" | "answered"
  createdAt   DateTime    @default(now())

  outcome     Outcome?
}

// Purpose: What happened
model Outcome {
  id String @id @default(cuid())
  conversationId String @unique
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  signalType OutcomeSignal
  signalClassification SignalClassification
  unexpectedLearning String? // What surprised you? Stored exactly as written.
  createdAt DateTime @default(now())
}

enum OutcomeSignal {
  no_answer
  spoke_briefly
  real_conversation
  not_interested
  wrong_fit
}

enum SignalClassification {
  supports
  contradicts
  unclear
  new_signal
}

// Purpose: What belief statement exists
// Status is informational only, never used for logic.
// Links to observations happen externally via queries, never encoded in schema.
model Assumption {
  id String @id @default(cuid())

  statement String @unique
  status AssumptionStatus? // Informational only, never used for logic
}

enum AssumptionStatus {
  emerging
  supported
  weak
  rejected
}

// Purpose: Raw observation events (decoupled from interpretation)
// No links to assumptions. Interpretation happens externally via queries.
// This ensures: database is memory dump of reality, not a brain.
model ObservationEvent {
  id String @id @default(cuid())

  sourceType ObservationSource
  sourceId String // ID of the source (outcome, review, or conversation)
  text String // Raw observed signal
  createdAt DateTime @default(now())
}

enum ObservationSource {
  review
  conversation
  outcome
}

// ============================================================================
// PROSPECT INTELLIGENCE SYSTEM
// ============================================================================

// Purpose: Feedback on prospect intelligence pages
// Minimal table: only what we need to learn if movement detection is accurate
model ProspectFeedback {
  id              String    @id @default(cuid())
  slug            String    // Business slug (e.g., "wilson-solicitors")
  feedbackType    String    // "yes" | "partly" | "no"
  referrer        String?   // "email" | "dashboard" | "direct"
  userAgent       String?   @map("user_agent")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([slug])
  @@index([createdAt])
  @@map("prospect_feedback")
}
